# ==============================================================================
# FRONTEND (Vite) — prefix all client-side variables with VITE_
# ==============================================================================

# Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Firebase
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=1:your-sender-id:web:your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Jitsi
VITE_JITSI_DOMAIN=meet.your-domain.com

# App behaviour
VITE_ORGANIZATION_SOWER_WALLET_NAME=your-sower-wallet-name
VITE_REQUIRE_VERIFICATION=true
VITE_VERIFICATION_REDIRECT=/verify-email
VITE_USE_FIREBASE_EMULATORS=false

# ==============================================================================
# SUPABASE EDGE FUNCTIONS (Deno.env — set via Supabase dashboard secrets)
# ==============================================================================

# Supabase (auto-injected in hosted environment, required for local dev)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Site URLs
PUBLIC_SITE_URL=https://your-app-domain.com
SITE_URL=https://your-app-domain.com

# Binance Pay
BINANCE_PAY_API_KEY=your-binance-pay-api-key
BINANCE_PAY_API_SECRET=your-binance-pay-api-secret
BINANCE_PAY_MERCHANT_ID=your-binance-merchant-id
BINANCE_PAY_API_BASE_URL=https://bpay.binanceapi.com
BINANCE_PAY_TRADE_TYPE=WEB
BINANCE_PAY_WEBHOOK_TOLERANCE_MS=300000
BINANCE_PAY_ORDER_EXPIRY_MINUTES=15

# Cryptomus
CRYPTOMUS_MERCHANT_ID=your-cryptomus-merchant-id
CRYPTOMUS_PAYMENT_API_KEY=your-cryptomus-payment-api-key
CRYPTOMUS_API_BASE_URL=https://api.cryptomus.com/v1


# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Replicate
REPLICATE_API_TOKEN=r8_your-replicate-api-token

# Email — Resend
RESEND_API_KEY=re_your-resend-api-key

# Email — Brevo
BREVO_API_KEY=your-brevo-api-key

# Web Push
VAPID_PRIVATE_KEY=your-vapid-private-key

# Lovable AI
LOVABLE_API_KEY=your-lovable-api-key

# Bestowal distribution (decimals, must sum correctly with platform cut)
BESTOWAL_TITHING_PERCENT=0.15
BESTOWAL_GROWER_PERCENT=0.10

# ==============================================================================
# JITSI SERVER (.env.jitsi — set on your Jitsi Meet server)
# ==============================================================================

PUBLIC_URL=https://meet.your-domain.com
XMPP_DOMAIN=meet.your-domain.com
XMPP_AUTH_DOMAIN=meet.your-domain.com
XMPP_MUC_DOMAIN=muc.meet.your-domain.com
XMPP_BOSH_URL_BASE=https://meet.your-domain.com/http-bind

ENABLE_LETSENCRYPT=1
LETSENCRYPT_DOMAIN=meet.your-domain.com
LETSENCRYPT_EMAIL=admin@your-domain.com

ENABLE_HTTP_REDIRECT=1
DISABLE_HTTPS=0

# Generate with: openssl rand -hex 16
JICOFO_AUTH_PASSWORD=generate-with-openssl-rand-hex-16
JVB_AUTH_PASSWORD=generate-with-openssl-rand-hex-16
JIGASI_XMPP_PASSWORD=generate-with-openssl-rand-hex-16

JVB_ADVERTISE_IPS=your-server-public-ip
JVB_ENABLE_APIS=rest,colibri

TURN_HOST=your-turn-server:443?transport=tcp
TURN_CREDENTIALS=your-secure-turn-credentials
