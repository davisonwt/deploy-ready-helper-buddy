{
  "rewrites": [
    { "source": "/((?!assets/|.*\\.(?:js|mjs|css|map|json|png|jpg|jpeg|webp|svg|ico|gif|woff|woff2|ttf|otf|mp3|mp4|webm|wav|txt|xml)).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
